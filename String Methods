import java.util.Arrays;

public class AdvancedStringDemo {
    public static void main(String[] args) {
        System.out.println("=== 1. Text Parsing & Conversion (split & toCharArray) ===");
        String rawLogData = "USER_01;Active;Admin;2026-06-25";
        
        // Split using a semicolon delimiter
        String[] logTokens = rawLogData.split(";");
        System.out.println("Parsed Log Tokens: " + Arrays.toString(logTokens));
        
        // Convert a single token into a character array
        String status = logTokens[1];
        char[] statusChars = status.toCharArray();
        System.out.print("Status Characters: ");
        for (char ch : statusChars) {
            System.out.print("[" + ch + "] ");
        }
        System.out.println("\n");


        System.out.println("=== 2. Safe Inspection (isEmpty vs isBlank) ===");
        String spacePadding = "   \u2007   "; // Contains standard spaces and a Unicode invisible space
        
        // isEmpty checks length only; isBlank checks if the string contains only whitespace
        System.out.println("Is string empty (length == 0)?: " + spacePadding.isEmpty()); 
        System.out.println("Is string blank (only whitespace)?: " + spacePadding.isBlank());
        System.out.println();


        System.out.println("=== 3. Structural Utility (repeat & join) ===");
        // Repeat a string pattern to form a UI separator line
        String starSeparator = "*".repeat(30);
        System.out.println(starSeparator);
        
        // Join standalone values together using a specific path delimiter
        String fallbackPath = String.join("/", "usr", "local", "bin", "config.json");
        System.out.println("Generated Filepath: " + fallbackPath);
        System.out.println(starSeparator);
        System.out.println();


        System.out.println("=== 4. Advanced Search (lastIndexOf, startsWith, endsWith) ===");
        String urlPath = "/assets/images/heroes/banner.png";
        
        // Route actions based on string context boundaries
        boolean isSecureAsset = urlPath.startsWith("/assets");
        boolean isImage = urlPath.endsWith(".png") || urlPath.endsWith(".jpg");
        System.out.println("Starts with /assets?: " + isSecureAsset);
        System.out.println("Is target an image asset?: " + isImage);
        
        // Find the index of the final occurrence of a character
        int finalSlashIndex = urlPath.lastIndexOf("/");
        String fileNameOnly = urlPath.substring(finalSlashIndex + 1);
        System.out.println("Isolated filename: " + fileNameOnly);
        System.out.println();


        System.out.println("=== 5. Pattern Matching & Transformation (replaceAll & strip) ===");
        String messyInput = "   \n\t ACME Corp - Order #12948-X \t\n   ";
        
        // strip() is a modern alternative to trim() that handles Unicode whitespace characters cleanly
        String cleanInput = messyInput.strip();
        System.out.println("Stripped input: '" + cleanInput + "'");
        
        // Mask confidential data using regular expressions inside replaceAll
        // Matches all digits (\\d) and replaces them with an X
        String maskedOrder = cleanInput.replaceAll("\\d", "X");
        System.out.println("Masked sensitive data: " + maskedOrder);
    }
}


