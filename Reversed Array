import java.util.*;
class Main {
    public static void main(String[] args) {
     
     int arr[] = {6,8,4,13,20,5,10,4,3};
    
     System.out.println("Reversed Array: ");
     for(int i =arr.length-1; i >= 0; i--){
         System.out.print(arr[i] + ",");
     }
     
    
    }
}


