class Solution {
    public void printPattern(int n) {
    
    for(int i=1; i<=n; i++){
        for(int j =1; j<=i; j++){
            
            if(i==1 || i==n || j==1 || j==i){
                System.out.print("* ");
            }else{
                System.out.print("  ");
            }
        }
        System.out.println();
    }
    }
}

