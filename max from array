import java.util.*;
class Main {
    public static void main(String[] args) {
     
     int arr[] = {2,8,4,3,5,10,4};
     int  max =arr[0] ;
     
     for(int i =0; i < arr.length; i++){
         if ( arr[i] > max){
             max = arr[i];
         }
     }
     System.out.println("Maximum number from array: " +max);
    
     
    }
}



