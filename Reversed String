import java.util.*;
class Main {
    public static void main(String[] args) {
        System.out.println("Enter the String : ");
        Scanner sc = new Scanner(System.in);
        String s = sc.next();
        String rev = "";
        
        for(int i = s.length()-1 ; i >=0 ; i--){
            rev = rev + s.charAt(i);
        }
        System.out.println("Reversed String :"+ rev);
    }
}


