import java.util.*;
class Main {
    public static void main(String[] args) {
      int arr[]= {1,2,3,2,6};
      
      for(int i=0;i<arr.length; i++){
          for(int j=i+1; j<arr.length; j++){
              if (arr[i] == arr[j]){
                  System.out.println("Duplicates in array : " +arr[i]);
                 
              }
          }
      }
         
    }
}


Output:

Duplicates in array : 2
