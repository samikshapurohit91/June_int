     int arr[] = {6,8,4,13,20,5,10,4,3};
     int  min =arr[0] ;
     
     for(int i =0; i < arr.length; i++){
         if ( arr[i] < min){
             min = arr[i];
         }
     }
     System.out.println("Minimum number from array: " +min);
    
     
    }
}


